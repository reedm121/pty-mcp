{
  "name": "pty-mcp",
  "version": "1.0.0",
  "description": "MCP server that gives AI coding agents a real pseudo-terminal for handling interactive CLI prompts",
  "type": "module",
  "bin": {
    "pty-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "pty",
    "pseudo-terminal",
    "claude-code",
    "interactive-cli",
    "model-context-protocol",
    "ai-agent"
  ],
  "author": "Reed Gantz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reedm121/pty-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/reedm121/pty-mcp/issues"
  },
  "homepage": "https://github.com/reedm121/pty-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "node-pty": "^1.0.0",
    "strip-ansi": "^7.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.19.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
